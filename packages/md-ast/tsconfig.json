{
    "compilerOptions": {
        "target": "es2023",
        "lib": ["ES2023"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "erasableSyntaxOnly": true,
        "skipLibCheck": true
    },
    "include": ["src"]
}
