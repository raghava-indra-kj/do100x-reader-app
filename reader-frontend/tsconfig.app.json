{
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "target": "es2023",
        "lib": [
            "ES2023",
            "DOM"
        ],
        "module": "esnext",
        "types": [
            "vite/client"
        ],
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        "noEmit": true,
        "jsx": "react-jsx",
        "paths": {
            "@boot/*": [
                "./src/boot/*"
            ],
            "@core/*": [
                "./src/core/*"
            ],
            "@di/*": [
                "./src/di/*"
            ],
            "@domain/*": [
                "./src/domain/*"
            ],
            "@lib/*": [
                "./src/lib/*"
            ],
            "@modules/*": [
                "./src/modules/*"
            ],
            "@styles/*": [
                "./src/styles/*"
            ],
            "@reader/md-ast": [
                "../packages/md-ast/src/index.ts"
            ]
        },
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "erasableSyntaxOnly": true,
        "noFallthroughCasesInSwitch": true
    },
    "include": [
        "src"
    ],
    "exclude": [
        "src/**/*.test.ts",
        "src/**/*.test.tsx"
    ]
}