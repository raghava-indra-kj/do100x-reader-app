generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model appuser {
  id         String  @id @default(uuid()) @db.VarChar(36)
  username   String  @db.VarChar(15)
  password   String  @db.VarChar(4)
  homepageId String? @db.VarChar(36)
}

model page {
  id            String    @id @default(uuid()) @db.VarChar(36)
  userId        String    @db.VarChar(36)
  parentId      String?   @db.VarChar(36)
  title         String    @db.VarChar(1000)
  content       String?   @db.LongText
  category      String?   @db.VarChar(255)
  sortOrder     Int
  childrenCount Int
  createdAt               DateTime  @db.DateTime(6)
  updatedAt               DateTime  @db.DateTime(6)
  deletedAt               DateTime? @db.DateTime(6)
  meaningSystemPrompt     String?   @db.Text
  explanationSystemPrompt String?   @db.Text
  doubtSystemPrompt       String?   @db.Text
}

model comment {
  id            String   @id @default(uuid()) @db.VarChar(36)
  pageId        String   @db.VarChar(36)
  pageTitle     String   @db.VarChar(1000)
  sectionTitle  String?  @db.VarChar(1000)
  selectedText  String   @db.Text
  body          String   @db.Text
  linkedPageId  String?  @db.VarChar(36)
  isExplanation Boolean  @default(false)
  createdAt     DateTime @db.DateTime(6)
  updatedAt     DateTime @db.DateTime(6)
}

model vocabulary {
  id        String   @id @default(uuid()) @db.VarChar(36)
  pageId    String   @db.VarChar(36)
  term      String   @db.VarChar(255)
  createdAt DateTime @db.DateTime(6)
}

model model_config {
  id                 String  @id @default(uuid()) @db.VarChar(36)
  userId             String  @unique @db.VarChar(36)
  baseUrl            String  @db.VarChar(500)
  apiKey             String  @db.VarChar(500)
  explanationModelId      String? @db.VarChar(255)
  meaningModelId          String? @db.VarChar(255)
  doubtModelId            String? @db.VarChar(255)
  meaningSystemPrompt     String? @db.Text
  explanationSystemPrompt String? @db.Text
  doubtSystemPrompt       String? @db.Text
}

model user_model {
  id      String @id @default(uuid()) @db.VarChar(36)
  userId  String @db.VarChar(36)
  name    String @db.VarChar(255)
  modelId String @db.VarChar(255)
}
