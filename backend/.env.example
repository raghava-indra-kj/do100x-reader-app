# Core server
PORT=3000

# Deployment environment
APP_ENV=development

# API
API_BODY_SIZE_LIMIT=1mb
API_BASE_PATH=/backend-api

# Database (runtime connection — used by the app)
DATABASE_HOST=localhost
DATABASE_PORT=3306
DATABASE_USER=your_user
DATABASE_PASSWORD=your_password
DATABASE_NAME=reader_app

# Database URL (used by Prisma CLI only — db push, migrate, studio)
DATABASE_URL="mysql://your_user:your_password@localhost:3306/reader_app"
