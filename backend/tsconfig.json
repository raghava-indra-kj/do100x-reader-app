{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": [
      "ES2020"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": [
        "src/core/*"
      ],
      "@lib/*": [
        "src/lib/*"
      ],
      "@i18n/*": [
        "src/i18n/*"
      ],
      "@modules/*": [
        "src/modules/*"
      ],
      "@prisma-generated": [
        "src/generated/prisma/client"
      ],
      "@prisma-generated/*": [
        "src/generated/prisma/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}