generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model appuser {
  id         String    @id @default(uuid()) @db.VarChar(36)
  name       String    @db.VarChar(100)
  email      String    @unique @db.VarChar(60)
  password   String    @db.VarChar(255)
  homepageId String?   @db.VarChar(36)
  createdAt  DateTime  @db.DateTime(6)
  homepage   page?     @relation("UserHomepage", fields: [homepageId], references: [id])
  sessions   session[]
  pages      page[]    @relation("UserPages")
  comments   comment[]
}

model session {
  id        String   @id @default(uuid()) @db.VarChar(36)
  userId    String   @db.VarChar(36)
  token     String   @unique @db.VarChar(64)
  isActive  Boolean  @default(true)
  createdAt DateTime @db.DateTime(6)
  user      appuser  @relation(fields: [userId], references: [id])
}

model page {
  id            String    @id @default(uuid()) @db.VarChar(36)
  userId        String    @db.VarChar(36)
  parentId      String?   @db.VarChar(36)
  title         String    @db.VarChar(1000)
  content       Json?
  category      String?   @db.VarChar(255)
  sortOrder     String    @db.VarChar(255)
  childrenCount Int
  createdAt     DateTime  @db.DateTime(6)
  updatedAt     DateTime  @db.DateTime(6)
  user          appuser   @relation("UserPages", fields: [userId], references: [id])
  parent        page?     @relation("PageChildren", fields: [parentId], references: [id])
  children      page[]    @relation("PageChildren")
  homepageFor   appuser[] @relation("UserHomepage")
  comments      comment[]
}

model comment {
  id            String   @id @default(uuid()) @db.VarChar(36)
  pageId        String   @db.VarChar(36)
  userId        String   @db.VarChar(36)
  selectionText String?  @db.MediumText
  comment       String   @db.Text
  createdAt     DateTime @db.DateTime(6)
  updatedAt     DateTime @db.DateTime(6)
  page          page     @relation(fields: [pageId], references: [id])
  user          appuser  @relation(fields: [userId], references: [id])
}
